{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "snelslagen",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "workers_dev": true,
  "routes": [
    { "pattern": "snelslagen.nl", "custom_domain": true },
    { "pattern": "www.snelslagen.nl", "custom_domain": true }
  ]
}
