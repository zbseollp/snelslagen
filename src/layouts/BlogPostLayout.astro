---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { formatDate, postDescription, readingMinutes, getRelatedPosts, displayTitle, type Post } from "@lib/posts";
import { SITE } from "@lib/site";

interface Props { post: Post; readMin?: number }
const { post, readMin = 3 } = Astro.props;
const { date, featuredImage, featuredImageAlt } = post.data;
const title = displayTitle(post);
const related = await getRelatedPosts(post, 3);
const desc = postDescription(post);

const jsonld = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  datePublished: date.toISOString(),
  description: desc,
  image: featuredImage ? new URL(featuredImage, SITE.url).href : undefined,
  author: { "@type": "Organization", name: SITE.name },
  publisher: { "@type": "Organization", name: SITE.name },
  mainEntityOfPage: new URL(`/${post.id}/`, SITE.url).href,
};
---
<BaseLayout title={post.data.metaTitle || title} description={desc} type="article" image={featuredImage}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />
  <article>
    <div class="border-b border-slate-100">
      <Container class="max-w-3xl py-3">
        <nav class="text-xs text-slate-400">
          <a href="/" class="hover:text-brand-600">Home</a>
          <span class="mx-1.5">/</span>
          <a href="/blog/" class="hover:text-brand-600">Blog</a>
          <span class="mx-1.5">/</span>
          <span class="text-slate-600">{title}</span>
        </nav>
      </Container>
    </div>

    <div class="bg-slate-900 text-white">
      <Container class="max-w-3xl py-10">
        {post.data.categories[0] && (
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-brand-400 mb-3">{post.data.categories[0]}</span>
        )}
        <h1 class="text-3xl font-extrabold tracking-tight leading-tight sm:text-4xl">{title}</h1>
        <div class="mt-4 flex items-center gap-3 text-sm text-slate-400">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          <span aria-hidden>·</span>
          <span>{readMin} min lezen</span>
        </div>
      </Container>
    </div>

    {featuredImage && (
      <Container class="max-w-4xl">
        <img src={featuredImage} alt={featuredImageAlt || title} width="1200" height="630"
             loading="eager" fetchpriority="high" decoding="sync"
             class="mt-6 aspect-[16/9] w-full object-cover" />
      </Container>
    )}

    <Container class="max-w-3xl">
      <a href="/verkeersborden-oefenen/" class="my-8 flex items-center justify-between gap-4 bg-brand-50 border border-brand-100 p-5 hover:bg-brand-100 transition-colors">
        <div>
          <p class="font-bold text-slate-900 text-sm">Direct oefenen?</p>
          <p class="text-sm text-slate-600">Test je kennis met de gratis verkeersbordenquiz. 20 vragen, geen account nodig.</p>
        </div>
        <span class="hidden shrink-0 bg-brand-600 text-white text-sm font-bold px-5 py-2 sm:inline-block">Start quiz →</span>
      </a>
      <div class="article-prose pb-(--spacing-section)">
        <slot />
      </div>
    </Container>
  </article>

  {related.length > 0 && (
    <section class="border-t border-slate-100 bg-slate-50">
      <Container class="py-(--spacing-section)">
        <h2 class="text-xl font-extrabold text-slate-900 mb-6">Lees ook</h2>
        <div class="divide-y divide-slate-200">
          {related.map((p) => (
            <article class="py-4 group">
              <a href={`/${p.id}/`} class="flex items-center gap-4">
                <div class="w-1 h-12 bg-slate-200 group-hover:bg-brand-500 transition-colors shrink-0"></div>
                <div>
                  <p class="font-bold text-slate-900 group-hover:text-brand-600 transition-colors leading-snug">{displayTitle(p)}</p>
                  <p class="text-xs text-slate-400 mt-0.5">{formatDate(p.data.date)}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </Container>
    </section>
  )}

  <section class="bg-brand-600 text-white">
    <Container class="py-10 flex flex-col sm:flex-row items-center justify-between gap-5">
      <div>
        <p class="font-extrabold text-lg">Klaar om te slagen?</p>
        <p class="text-brand-200 text-sm mt-0.5">Meer dan 423.000 cursisten gingen je voor.</p>
      </div>
      <a href="/cursus/" class="shrink-0 bg-white text-brand-700 font-bold px-6 py-2.5 text-sm hover:bg-brand-50 transition-colors">
        Bekijk de cursus →
      </a>
    </Container>
  </section>
</BaseLayout>
