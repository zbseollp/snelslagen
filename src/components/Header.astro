---
import Container from "@components/Container.astro";
import { SITE } from "@lib/site";
const path = new URL(Astro.request.url).pathname;
const isActive = (href: string) => href === "/" ? path === "/" : path.startsWith(href);
---
<header class="sticky top-0 z-50 bg-white shadow-sm border-b border-slate-100">
  <Container class="flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 font-display text-xl font-extrabold tracking-tight text-slate-900">
      <div class="w-9 h-9 bg-brand-600 flex items-center justify-center shrink-0" style="border-radius:3px">
        <svg width="22" height="16" viewBox="0 0 22 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 13L1 11.5C1 11.5 5 5.5 11 5.5C17 5.5 21 11.5 21 11.5L19 13" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <circle cx="11" cy="5.5" r="2" fill="white"/>
          <path d="M11 5.5L14 10.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <span>Snel<span class="text-brand-600">Slagen</span></span>
    </a>

    <nav class="hidden items-center lg:flex" aria-label="Hoofdmenu">
      {SITE.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "relative px-4 py-5 text-sm font-medium transition-colors",
            isActive(item.href)
              ? "text-brand-600 after:absolute after:bottom-0 after:left-4 after:right-4 after:h-0.5 after:bg-brand-600"
              : "text-slate-600 hover:text-brand-600",
          ]}
        >{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href="/cursus/" class="hidden lg:inline-flex items-center bg-brand-600 text-white text-sm font-bold px-4 py-2 hover:bg-brand-700 transition-colors" style="border-radius:3px">
        Start cursus
      </a>
      <a href="/mijn-account/" class="hidden lg:flex items-center gap-1.5 border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 transition hover:border-brand-400 hover:text-brand-600" style="border-radius:3px">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        Account
      </a>
      <button
        data-menu-toggle
        class="inline-flex items-center justify-center p-2 text-slate-600 lg:hidden"
        aria-label="Menu openen" aria-expanded="false"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </Container>

  <div data-mobile-menu class="hidden border-t border-slate-100 bg-white lg:hidden">
    <Container class="flex flex-col py-2 pb-4">
      {SITE.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-2.5 text-sm font-medium border-l-2",
            isActive(item.href) ? "text-brand-600 border-brand-600 bg-brand-50" : "text-slate-700 border-transparent hover:bg-slate-50",
          ]}
        >{item.label}</a>
      ))}
      <div class="mt-3 px-3 flex gap-2">
        <a href="/cursus/" class="flex-1 text-center bg-brand-600 text-white text-sm font-bold py-2.5 hover:bg-brand-700 transition-colors">Start cursus</a>
        <a href="/mijn-account/" class="flex-1 text-center border border-slate-200 text-slate-700 text-sm font-medium py-2.5 hover:bg-slate-50 transition-colors">Account</a>
      </div>
    </Container>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
