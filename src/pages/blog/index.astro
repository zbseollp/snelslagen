---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { getAllPosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getAllPosts();
---
<BaseLayout
  title={`Blog | ${SITE.name}`}
  description="Artikelen en tips over het CBR theorie-examen, verkeersborden, rijles en alles rondom je rijbewijs."
>
  <!-- Page header -->
  <div class="bg-slate-900 text-white">
    <Container class="py-14">
      <p class="text-xs font-bold uppercase tracking-widest text-brand-400 mb-3">Theorieblog</p>
      <h1 class="text-4xl font-extrabold tracking-tight">Blog</h1>
      <p class="mt-3 text-slate-400 max-w-xl">Tips, uitleg en nieuws over het CBR theorie-examen en alles wat met rijbewijs te maken heeft.</p>
    </Container>
  </div>

  <Container class="py-(--spacing-section)">
    {posts.length === 0 ? (
      <p class="text-slate-500 text-center py-12">Nog geen artikelen gepubliceerd.</p>
    ) : (
      <div class="divide-y divide-slate-100">
        {posts.map((post) => {
          const title = displayTitle(post);
          const desc = displayDescription(post);
          return (
            <article class="py-6 group">
              <a href={`/${post.id}/`} class="flex items-start gap-5">
                <div class="w-1 self-stretch bg-slate-200 group-hover:bg-brand-500 transition-colors shrink-0 mt-1"></div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 text-xs text-slate-400 mb-2">
                    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                    {post.data.categories[0] && (
                      <span class="bg-slate-100 text-slate-500 px-2 py-0.5 font-medium">{post.data.categories[0]}</span>
                    )}
                  </div>
                  <h2 class="text-lg font-bold text-slate-900 group-hover:text-brand-600 transition-colors leading-snug">{title}</h2>
                  {desc && <p class="mt-1 text-sm text-slate-500 leading-relaxed line-clamp-2">{desc}</p>}
                </div>
                {post.data.featuredImage && (
                  <img
                    src={post.data.featuredImage} alt={post.data.featuredImageAlt || title}
                    class="w-24 h-16 object-cover shrink-0 hidden sm:block"
                    loading="lazy"
                  />
                )}
              </a>
            </article>
          );
        })}
      </div>
    )}
  </Container>
</BaseLayout>
