---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { getAllPosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const posts = await getAllPosts();
  return paginate(posts, { pageSize: 24 });
}

const { page } = Astro.props as any;
const isFirst = page.currentPage === 1;

type PageItem = { type: "page"; n: number } | { type: "ellipsis"; key: string };
const pageItems: PageItem[] = [];
for (let n = 1; n <= page.lastPage; n++) {
  const near = Math.abs(n - page.currentPage) <= 2 || n === 1 || n === page.lastPage;
  if (near) {
    pageItems.push({ type: "page", n });
  } else if (pageItems[pageItems.length - 1]?.type !== "ellipsis") {
    pageItems.push({ type: "ellipsis", key: `e${n}` });
  }
}
---
<BaseLayout
  title={isFirst ? `Blog | ${SITE.name}` : `Blog - pagina ${page.currentPage} | ${SITE.name}`}
  description="Artikelen en tips over het CBR theorie-examen, verkeersborden, rijles en alles rondom je rijbewijs."
>
  <!-- Page header -->
  <div class="bg-slate-900 text-white">
    <Container class="py-14">
      <p class="text-xs font-bold uppercase tracking-widest text-brand-400 mb-3">Theorieblog</p>
      <div class="flex items-end justify-between flex-wrap gap-4">
        <div>
          <h1 class="text-4xl font-extrabold tracking-tight">Blog</h1>
          {!isFirst && <p class="text-slate-400 text-sm mt-1">Pagina {page.currentPage} van {page.lastPage}</p>}
          <p class="mt-3 text-slate-400 max-w-xl">Tips, uitleg en nieuws over het CBR theorie-examen en alles wat met rijbewijs te maken heeft.</p>
        </div>
        <span class="bg-white/10 text-slate-300 text-xs font-semibold px-3 py-1 rounded-full border border-white/10">{page.total} artikelen</span>
      </div>
    </Container>
  </div>

  <Container class="py-(--spacing-section)">
    {page.data.length === 0 ? (
      <p class="text-slate-500 text-center py-12">Nog geen artikelen gepubliceerd.</p>
    ) : (
      <div class="divide-y divide-slate-100">
        {page.data.map((post: any) => {
          const title = displayTitle(post);
          const desc = displayDescription(post);
          return (
            <article class="py-6 group">
              <a href={`/${post.id}/`} class="flex items-start gap-5">
                <div class="w-1 self-stretch bg-slate-200 group-hover:bg-brand-500 transition-colors shrink-0 mt-1"></div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 text-xs text-slate-400 mb-2">
                    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                    {post.data.categories[0] && (
                      <span class="bg-slate-100 text-slate-500 px-2 py-0.5 font-medium">{post.data.categories[0]}</span>
                    )}
                  </div>
                  <h2 class="text-lg font-bold text-slate-900 group-hover:text-brand-600 transition-colors leading-snug">{title}</h2>
                  {desc && <p class="mt-1 text-sm text-slate-500 leading-relaxed line-clamp-2">{desc}</p>}
                </div>
                {post.data.featuredImage && (
                  <img
                    src={post.data.featuredImage} alt={post.data.featuredImageAlt || title}
                    class="w-24 h-16 object-cover shrink-0 hidden sm:block"
                    loading="lazy"
                  />
                )}
              </a>
            </article>
          );
        })}
      </div>
    )}

    {page.lastPage > 1 && (
      <nav class="mt-12 flex items-center justify-center gap-2" aria-label="Paginatie">
        {page.url.prev && (
          <a href={page.url.prev} class="flex items-center gap-1.5 px-4 py-2 text-sm font-semibold border border-slate-200 rounded-lg text-slate-700 hover:border-brand-300 hover:text-brand-700 transition-colors">
            ← Vorige
          </a>
        )}

        <div class="flex items-center gap-1">
          {pageItems.map((item) =>
            item.type === "ellipsis"
              ? <span class="px-2 text-slate-400 text-sm select-none">…</span>
              : item.n === page.currentPage
                ? <span class="w-9 h-9 flex items-center justify-center text-sm font-semibold rounded-lg bg-brand-600 text-white" aria-current="page">{item.n}</span>
                : <a href={item.n === 1 ? "/blog/" : `/blog/${item.n}/`} class="w-9 h-9 flex items-center justify-center text-sm font-semibold rounded-lg border border-slate-200 text-slate-600 hover:border-brand-300 hover:text-brand-700 transition-colors">{item.n}</a>
          )}
        </div>

        {page.url.next && (
          <a href={page.url.next} class="flex items-center gap-1.5 px-4 py-2 text-sm font-semibold border border-slate-200 rounded-lg text-slate-700 hover:border-brand-300 hover:text-brand-700 transition-colors">
            Volgende →
          </a>
        )}
      </nav>
    )}
  </Container>
</BaseLayout>
