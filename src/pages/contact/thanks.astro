---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
---
<BaseLayout
  title="Bericht verzonden | SnelSlagen.nl"
  description="Je bericht is ontvangen. We reageren binnen 1 werkdag."
  noindex={true}
>
  <Container class="py-(--spacing-section) max-w-lg text-center">
    <div class="w-16 h-16 bg-brand-600 flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <h1 class="text-3xl font-extrabold text-slate-900">Bericht ontvangen</h1>
    <p class="mt-3 text-slate-500">Bedankt voor je bericht. We reageren doorgaans binnen 1 werkdag.</p>
    <div class="mt-8 flex justify-center gap-3 flex-wrap">
      <a href="/" class="inline-flex items-center bg-brand-600 text-white font-bold px-6 py-2.5 text-sm hover:bg-brand-700 transition-colors">Naar home</a>
      <a href="/cursus/" class="inline-flex items-center border-2 border-slate-200 text-slate-700 font-bold px-6 py-2.5 text-sm hover:border-brand-500 hover:text-brand-600 transition-colors">Bekijk cursus</a>
    </div>
  </Container>
</BaseLayout>
